\pard\sa180\sl276\slmult1\b\fs24 6.6 Sample Schema\b0\fs22\par
\par
\pard\sa120\sl240\slmult1\f1\fs18
CREATE TABLE schools (\par
  id BIGSERIAL PRIMARY KEY,\par
  slug VARCHAR(120) NOT NULL UNIQUE,\par
  name VARCHAR(255) NOT NULL,\par
  description TEXT,\par
  sort_order INT NOT NULL DEFAULT 0,\par
  is_active BOOLEAN NOT NULL DEFAULT TRUE\par
);\par
\par
CREATE TABLE programs (\par
  id BIGSERIAL PRIMARY KEY,\par
  school_id BIGINT NOT NULL REFERENCES schools(id),\par
  department_id BIGINT NULL,\par
  slug VARCHAR(160) NOT NULL UNIQUE,\par
  title VARCHAR(255) NOT NULL,\par
  level VARCHAR(32) NOT NULL,\par
  degree_type VARCHAR(64) NOT NULL,\par
  duration_months INT NOT NULL,\par
  mode VARCHAR(32) NOT NULL DEFAULT 'full_time',\par
  overview TEXT,\par
  eligibility_text TEXT,\par
  intake_year INT NOT NULL,\par
  status VARCHAR(32) NOT NULL DEFAULT 'active'\par
);\par
\par
CREATE TABLE applications (\par
  id BIGSERIAL PRIMARY KEY,\par
  application_no VARCHAR(32) NOT NULL UNIQUE,\par
  user_id BIGINT NOT NULL REFERENCES users(id),\par
  intake_id BIGINT NOT NULL REFERENCES intakes(id),\par
  program_id BIGINT NOT NULL REFERENCES programs(id),\par
  current_status VARCHAR(32) NOT NULL DEFAULT 'draft',\par
  payment_status VARCHAR(32) NOT NULL DEFAULT 'pending',\par
  interview_status VARCHAR(32) NOT NULL DEFAULT 'not_required',\par
  entrance_test_status VARCHAR(32) NOT NULL DEFAULT 'not_required',\par
  final_decision VARCHAR(32),\par
  submitted_at TIMESTAMP NULL,\par
  created_at TIMESTAMP NOT NULL DEFAULT NOW(),\par
  updated_at TIMESTAMP NOT NULL DEFAULT NOW()\par
);\par
