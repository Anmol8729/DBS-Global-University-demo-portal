\pard\sa220\sl280\slmult1\b\fs28 5. Backend Architecture\b0\fs22\par
\par
\pard\sa180\sl276\slmult1\b\fs24 5.1 Recommended Stack\b0\fs22\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Backend framework: NestJS with TypeScript\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Frontend: Next.js\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Primary database: PostgreSQL\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Cache and queue backing: Redis\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Storage: S3-compatible object storage\par
\par
\pard\sa180\sl276\slmult1\b\fs24 5.2 Architecture Pattern\b0\fs22\par
\par
\pard\sa120\sl240\slmult1\f0\fs22 Recommendation: Modular Monolith\par
\par
\pard\sa120\sl240\slmult1\f0\fs22 Why this fits DGU:\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab DGU has medium complexity with shared domain data across admissions, content, and programs\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab University teams usually need lower operational overhead than microservices\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Admissions traffic is seasonal rather than continuously extreme\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Shared reporting and admin workflows are simpler in a modular monolith\par
\par
\pard\sa180\sl276\slmult1\b\fs24 5.3 Service Modules\b0\fs22\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22\bullet\tab Auth Module\par
