\pard\sa220\sl280\slmult1\b\fs28 7. Backend Logic Flows\b0\fs22\par
\par
\pard\sa180\sl276\slmult1\b\fs24 7.1 Admission Flow\b0\fs22\par
\par
\pard\sa120\sl240\slmult1\f0\fs22 Flow:\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 1. Applicant registers\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 2. System creates user and applicant role\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 3. Verification email or SMS is sent\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 4. Applicant starts draft application\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 5. Program and intake are selected\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 6. Dynamic eligibility rules are loaded\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 7. Applicant fills profile and academics and uploads documents\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 8. Server validates required fields and checklist\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 9. Payment order is created\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 10. Payment webhook confirms success\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 11. Application moves from draft to submitted\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 12. Counsellor or admissions queue assignment happens\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 13. Eligibility engine determines interview, test, or direct shortlist\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 14. Status history is recorded\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 15. Notification is sent\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 16. Admin updates final decision\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 17. Accepted applicant is synced to SIS or ERP\par
\par
\pard\sa180\sl276\slmult1\b\fs24 7.2 Course Browsing Flow\b0\fs22\par
\par
\pard\sa120\sl240\slmult1\f0\fs22 Flow:\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 1. User filters by school, level, or specialization\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 2. API checks Redis cache for the filter signature\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 3. On miss, PostgreSQL query runs using indexed columns\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 4. API returns summary fields only\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 5. Program detail page is cached separately\par
\par
\pard\sa180\sl276\slmult1\b\fs24 7.3 CMS Update Flow\b0\fs22\par
\par
\pard\sa120\sl240\slmult1\f0\fs22 Flow:\par
\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 1. Editor creates draft content\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 2. Optional review happens\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 3. Content is published or scheduled\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 4. Publish triggers cache invalidation and search refresh\par
\pard\li360\fi-180\sa120\sl240\slmult1\f0\fs22 5. Homepage and listing pages update\par
\par
