  p.id,\par
  p.slug,\par
  p.title,\par
  p.excerpt,\par
  p.published_at\par
FROM posts p\par
WHERE p.type = 'campus_news'\par
  AND p.status = 'published'\par
ORDER BY p.published_at DESC\par
LIMIT 12 OFFSET 0;\par
